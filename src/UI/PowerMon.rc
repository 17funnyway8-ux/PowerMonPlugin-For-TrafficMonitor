#include "resource.h"
#include <windows.h>
#include <commctrl.h>

// 插件配置属性对话框资源定义
IDD_OPTIONS_DLG DIALOGEX 0, 0, 240, 190
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "功耗监控插件设置"
FONT 9, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    // 监控项开关组
    GROUPBOX        "数据源监控项配置", IDC_STATIC, 10, 10, 220, 75
    CONTROL         "启用 CPU 功耗监控", IDC_CHECK_CPU_MON, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 20, 25, 120, 10
    CONTROL         "启用 GPU 功耗监控", IDC_CHECK_GPU_MON, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 20, 40, 120, 10
    CONTROL         "启用 电池放电功率监控", IDC_CHECK_BATTERY_MON, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 20, 55, 120, 10
    CONTROL         "智能显示模式 (自适应电源/电池)", IDC_CHECK_SMART_MODE, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 20, 70, 180, 10

    // 显示格式配置组
    GROUPBOX        "显示格式配置", IDC_STATIC, 10, 90, 220, 70
    LTEXT           "数字显示长度 (小数位数 0-3):", IDC_STATIC, 20, 105, 110, 8
    EDITTEXT        IDC_EDIT_DIGIT_LENGTH, 135, 103, 30, 12, ES_AUTOHSCROLL | ES_NUMBER
    CONTROL         "", IDC_SPIN_DIGIT_LENGTH, UPDOWN_CLASS, UDS_SETBUDDYINT | UDS_ALIGNRIGHT | UDS_AUTOBUDDY | UDS_ARROWKEYS | UDS_NOTHOUSANDS, 155, 103, 10, 14
    
    LTEXT           "间距控制 (空格数 0-5):", IDC_STATIC, 20, 122, 110, 8
    EDITTEXT        IDC_EDIT_SPACING_CONTROL, 135, 120, 30, 12, ES_AUTOHSCROLL | ES_NUMBER
    CONTROL         "", IDC_SPIN_SPACING_CONTROL, UPDOWN_CLASS, UDS_SETBUDDYINT | UDS_ALIGNRIGHT | UDS_AUTOBUDDY | UDS_ARROWKEYS | UDS_NOTHOUSANDS, 155, 120, 10, 14

    LTEXT           "自定义单位字符 (最大15字符):", IDC_STATIC, 20, 140, 110, 8
    EDITTEXT        IDC_EDIT_UNIT_STRING, 135, 138, 80, 12, ES_AUTOHSCROLL

    // 确认与取消
    DEFPUSHBUTTON   "确定", IDOK, 125, 168, 50, 14
    PUSHBUTTON      "取消", IDCANCEL, 180, 168, 50, 14
END
